/*
 * Smart Irrigation + Plant Talking System
 */

#include <DHT.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// Pin definitions
#define DHTPIN 4
#define DHTTYPE DHT11
#define SOIL_MOISTURE A0
#define RELAY_PIN 8
#define BUZZER 7

bool RELAY_ACTIVE_HIGH = false; 

LiquidCrystal_I2C lcd(0x27, 16, 2);

// Thresholds
int wetThreshold = 600;
int dryThreshold = 800;
int pumpDuration = 15000;

// State variables
bool pumpRunning = false;
unsigned long pumpStartTime = 0;
unsigned long lastSensorRead = 0;
unsigned long lastLCDUpdate = 0;
unsigned long lastForceOff = 0;

const int sensorInterval = 1000;
const int lcdInterval = 1500;
const int forceOffInterval = 2000;

DHT dht(DHTPIN, DHTTYPE);

int soilMoisture = 0;
float temperature = 0;
float humidity = 0;
bool dhtError = false;

void setup() {
  Serial.begin(9600);

  pinMode(RELAY_PIN, OUTPUT);
  pinMode(BUZZER, OUTPUT);

  forceRelayOff();
  digitalWrite(BUZZER, LOW);

  Wire.begin();
  lcd.init();
  lcd.backlight();
  lcd.clear();

  lcd.setCursor(0, 0);
  lcd.print("Smart Irrigation");
  lcd.setCursor(0, 1);
  lcd.print("Plant System");
  delay(2000);

  dht.begin();
}

void loop() {
  unsigned long currentTime = millis();
  
  // Read sensors
  if (currentTime - lastSensorRead >= sensorInterval) {
    lastSensorRead = currentTime;
    readSensors();
    controlPumpWithForceOff();
    plantBuzzerAlert();
  }
  
  // Update LCD
  if (currentTime - lastLCDUpdate >= lcdInterval) {
    lastLCDUpdate = currentTime;
    updateLCD();
  }
  
  // Force relay OFF periodically
  if (currentTime - lastForceOff >= forceOffInterval) {
    lastForceOff = currentTime;
    if (!pumpRunning) {
      forceRelayOff();
    }
  }
  
  // Safety timeout
  if (pumpRunning && (currentTime - pumpStartTime >= pumpDuration)) {
    forcePumpOff();
    showMessage("SAFETY STOP!", "Pump OFF");
  }

  delay(50);
}

void readSensors() {
  soilMoisture = analogRead(SOIL_MOISTURE);
  humidity = dht.readHumidity();
  temperature = dht.readTemperature();
  
  if (isnan(humidity) || isnan(temperature)) {
    dhtError = true;
  } else {
    dhtError = false;
  }

  Serial.print("Moisture: ");
  Serial.print(soilMoisture);
  Serial.print(" Temp: ");
  Serial.print(temperature);
  Serial.print(" Humidity: ");
  Serial.println(humidity);
}

void controlPumpWithForceOff() {
  if (pumpRunning && soilMoisture < wetThreshold) {
    forcePumpOff();
  } 
  else if (!pumpRunning && soilMoisture > dryThreshold) {
    turnPumpOn();
  } 
  else {
    if (!pumpRunning) {
      forceRelayOff();
    }
  }
}

void turnPumpOn() {
  if (RELAY_ACTIVE_HIGH) {
    digitalWrite(RELAY_PIN, HIGH);
  } else {
    digitalWrite(RELAY_PIN, LOW);
  }

  pumpRunning = true;
  pumpStartTime = millis();
  showMessage("PUMP ON", "Watering...");
}

void forcePumpOff() {
  forceRelayOff();
  pumpRunning = false;
  showMessage("PUMP OFF", "Soil Wet");
}

void forceRelayOff() {
  if (RELAY_ACTIVE_HIGH) {
    digitalWrite(RELAY_PIN, LOW);
  } else {
    digitalWrite(RELAY_PIN, HIGH);
  }
}

// ---------------- PLANT TALKING SYSTEM ----------------

String getPlantMessage() {
  if (soilMoisture > dryThreshold + 50) {
    return "I AM DYING!";
  }
  else if (soilMoisture > dryThreshold) {
    return "I AM THIRSTY";
  }
  else if (soilMoisture < wetThreshold - 50) {
    return "TOO MUCH WATER";
  }
  else if (temperature > 34) {
    return "ITS TOO HOT";
  }
  else if (temperature < 18) {
    return "I AM COLD";
  }
  else if (humidity < 30) {
    return "AIR TOO DRY";
  }
  else {
    return "I AM HAPPY";
  }
}

// Buzzer alert when very dry
void plantBuzzerAlert() {
  if (soilMoisture > dryThreshold + 50) {
    digitalWrite(BUZZER, HIGH);
  } else {
    digitalWrite(BUZZER, LOW);
  }
}

// LCD Update
void updateLCD() {
  lcd.clear();
  
  lcd.setCursor(0, 0);
  lcd.print("T:");
  lcd.print(temperature, 1);
  lcd.print(" H:");
  lcd.print(humidity, 0);

  lcd.setCursor(0, 1);
  lcd.print(getPlantMessage());
}

// Display message temporarily
void showMessage(String line1, String line2) {
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print(line1);
  lcd.setCursor(0, 1);
  lcd.print(line2);
  delay(1500);
}
